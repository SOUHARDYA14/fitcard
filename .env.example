FLASK_SECRET_KEY=replace-with-a-long-random-string

# Google OAuth (create credentials at https://console.cloud.google.com/apis/credentials
# -> "OAuth client ID" -> Web application -> add
# http://127.0.0.1:5000/auth/google/callback as an Authorized redirect URI).
# If left blank, "Sign in with Google" is hidden and only email/password login works.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
